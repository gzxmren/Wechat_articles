  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 820 300" font-family="'PingFang SC','Microsoft YaHei',sans-serif">
   <defs>
    <filter x="-4%" y="-4%" width="108%" height="108%">
     <fedropshadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08">
     </fedropshadow>
    </filter>
    <linearGradient x1="0" y1="0" x2="1" y2="1">
     <stop offset="0%" stop-color="#6366F1">
     </stop>
     <stop offset="100%" stop-color="#818CF8">
     </stop>
    </linearGradient>
    <linearGradient x1="0" y1="0" x2="1" y2="1">
     <stop offset="0%" stop-color="#14B8A6">
     </stop>
     <stop offset="100%" stop-color="#5EEAD4">
     </stop>
    </linearGradient>
    <linearGradient x1="0" y1="0" x2="1" y2="1">
     <stop offset="0%" stop-color="#F59E0B">
     </stop>
     <stop offset="100%" stop-color="#FBBF24">
     </stop>
    </linearGradient>
   </defs>
   <rect width="820" height="300" rx="16" fill="#FAFBFC">
   </rect>
   <text x="410" y="42" text-anchor="middle" font-size="20" font-weight="bold" fill="#1E293B">
    
    
    
    Skills 的三大核心价值
   </text>
   <rect x="30" y="70" width="240" height="210" rx="14" fill="#fff" stroke="#E2E8F0" stroke-width="1" filter="url(#shadow)">
   </rect>
   <circle cx="150" cy="130" r="36" fill="url(#g1)" opacity="0.12">
   </circle>
   <circle cx="150" cy="130" r="28" fill="url(#g1)">
   </circle>
   <rect x="136" y="118" width="28" height="20" rx="2" fill="none" stroke="#fff" stroke-width="2">
   </rect>
   <line x1="150" y1="118" x2="150" y2="138" stroke="#fff" stroke-width="1.5">
   </line>
   <text x="150" y="185" text-anchor="middle" font-size="15" font-weight="bold" fill="#4338CA">
    
    
    
    知识沉淀与复用
   </text>
   <text x="150" y="210" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    反复使用的流程
   </text>
   <text x="150" y="228" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    固化为技能
   </text>
   <text x="150" y="246" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    避免重复造轮子
   </text>
   <text x="150" y="268" text-anchor="middle" font-size="11" fill="#818CF8">
    
    
    
    💡 写好一次 = N 次复用
   </text>
   <rect x="290" y="70" width="240" height="210" rx="14" fill="#fff" stroke="#E2E8F0" stroke-width="1" filter="url(#shadow)">
   </rect>
   <circle cx="410" cy="130" r="36" fill="url(#g2)" opacity="0.12">
   </circle>
   <circle cx="410" cy="130" r="28" fill="url(#g2)">
   </circle>
   <rect x="396" y="118" width="12" height="12" rx="2" fill="none" stroke="#fff" stroke-width="2">
   </rect>
   <rect x="410" y="118" width="12" height="12" rx="2" fill="none" stroke="#fff" stroke-width="2">
   </rect>
   <rect x="396" y="132" width="12" height="12" rx="2" fill="none" stroke="#fff" stroke-width="2">
   </rect>
   <rect x="410" y="132" width="12" height="12" rx="2" fill="none" stroke="#fff" stroke-width="2">
   </rect>
   <text x="410" y="185" text-anchor="middle" font-size="15" font-weight="bold" fill="#0F766E">
    
    
    
    模块化架构
   </text>
   <text x="410" y="210" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    每个技能独立
   </text>
   <text x="410" y="228" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    易于测试和维护
   </text>
   <text x="410" y="246" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    灵活扩展组合
   </text>
   <text x="410" y="268" text-anchor="middle" font-size="11" fill="#14B8A6">
    
    
    
    🧩 即插即用，互不干扰
   </text>
   <rect x="550" y="70" width="240" height="210" rx="14" fill="#fff" stroke="#E2E8F0" stroke-width="1" filter="url(#shadow)">
   </rect>
   <circle cx="670" cy="130" r="36" fill="url(#g3)" opacity="0.12">
   </circle>
   <circle cx="670" cy="130" r="28" fill="url(#g3)">
   </circle>
   <circle cx="660" cy="130" r="10" fill="none" stroke="#fff" stroke-width="2">
   </circle>
   <circle cx="680" cy="130" r="10" fill="none" stroke="#fff" stroke-width="2">
   </circle>
   <line x1="650" y1="130" x2="620" y2="130" stroke="#fff" stroke-width="2">
   </line>
   <line x1="690" y1="130" x2="720" y2="130" stroke="#fff" stroke-width="2">
   </line>
   <text x="670" y="185" text-anchor="middle" font-size="15" font-weight="bold" fill="#B45309">
    
    
    
    无限可能性
   </text>
   <text x="670" y="210" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    通过组合不同技能
   </text>
   <text x="670" y="228" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    构建复杂工作流
   </text>
   <text x="670" y="246" text-anchor="middle" font-size="12" fill="#64748B">
    
    
    
    生态持续增长
   </text>
   <text x="670" y="268" text-anchor="middle" font-size="11" fill="#F59E0B">
    
    
    
    🚀 技能组合 = 能力倍增
   </text>
   <line x1="270" y1="175" x2="290" y2="175" stroke="#CBD5E1" stroke-width="1.5" stroke-dasharray="4,3">
   </line>
   <line x1="530" y1="175" x2="550" y2="175" stroke="#CBD5E1" stroke-width="1.5" stroke-dasharray="4,3">
   </line>
  </svg>
